<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="Employee Details"
        contentWidth="400px">

        <content>
            <VBox class="sapUiMediumMargin">
                <Text text="Employee Information" />
            </VBox>
        </content>

        <beginButton>
            <Button
                text="Close"
                press="onCloseDialog" />
        </beginButton>

    </Dialog>

</core:FragmentDefinition>