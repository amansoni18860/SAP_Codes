<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sap.ui.demo.learn.controller.App"
    displayBlock="true">

    <Shell>
        <App>
            <pages>
                <Page title="{i18n>homePageTitle}">
                <headerContent>
                <Button icon="sap-icon://home" press="onHomePress"/>
                </headerContent>
                    <content>
<mvc:XMLView viewName="sap.ui.demo.learn.view.HelloPanel" type="XML" />
<mvc:XMLView viewName="sap.ui.demo.learn.view.Invoices" type="XML" />
                    </content>
                </Page>
            </pages>
        </App>
    </Shell>

</mvc:View>