<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sap.ui.demo.learn.controller.App"
    displayBlock="true">

    <Shell>
        <App>
            <pages>
                <Page title="{i18n>homePageTitle}">
                    <content>
                        <Panel headerText="{i18n>PanelHeader}">

                            <content>

                                <Button
                                    text="{i18n>showHelloBtn}"
                                    press="onPress" />

                                <VBox class="sapUiSmallMargin">

                                    <Input
                                        value="{/recipient/name}"
                                        valueLiveUpdate="true" />

                                    <Text
                                        text="{= 'Hello ' + ${/recipient/name} }" />

                                </VBox>

                            </content>

                        </Panel>
                    </content>
                </Page>
            </pages>
        </App>
    </Shell>

</mvc:View>