<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="helloDialog"
        title="Welcome"
        contentWidth="25rem">

        <content>

            <VBox
                class="sapUiMediumMargin"
                alignItems="Center">

                <core:Icon
                    src="sap-icon://hello-world"
                    size="3rem"
                    color="#0a6ed1"/>

                <Title
                    text="{= 'Welcome ' + ${/recipient/name} }"
                    level="H3"/>

                <Text
                    text="{= 'Hello ' + ${/recipient/name} + ', welcome to SAP UI5.' }"
                    class="sapUiSmallMarginTop"/>

            </VBox>

        </content>

        <beginButton>

            <Button
                text="OK"
                type="Emphasized"
                press=".onCloseDialog"/>

        </beginButton>

    </Dialog>

</core:FragmentDefinition>