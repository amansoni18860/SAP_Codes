<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="helloDialog"
        title="Hello Dialog"
        contentWidth="25rem">

        <content>

            <VBox
                class="sapUiMediumMargin"
                alignItems="Center">

                <core:Icon
                    src="sap-icon://hello-world"
                    size="3rem"
                    color="#0a6ed1"
                    class="sapUiSmallMarginBottom"/>

                <Title
                    text="{= 'Welcome ' + ${/recipient/name} }"
                    level="H3" />

                <Text
                    text="{= 'Hello ' + ${/recipient/name} + ', welcome to SAP UI5 Fragments.' }"
                    class="sapUiSmallMarginTop" />

            </VBox>

        </content>

        <beginButton>
            <Button
                text="OK"
                type="Emphasized"
                press=".onCloseDialog" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCloseDialog" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>