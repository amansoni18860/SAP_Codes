<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="sap.ui.demo.learn.controller.HelloPanel">

    <Panel
        headerText="Hello UI5"
        class="sapUiResponsiveMargin">

        <content>

            <HBox
                alignItems="Center"
                class="sapUiSmallMargin">

                <Button
                    text="Open Dialog"
                    icon="sap-icon://message-popup"
                    press=".onPressDialog"
                    class="sapUiTinyMarginEnd"
                    id="helloDialogButton"/>

                <Input
                    value="{/recipient/name}"
                    valueLiveUpdate="true"
                    width="15rem"
                    class="sapUiTinyMarginEnd"/>

                <Text
                    text="{= 'Hello ' + ${/recipient/name} }"/>

            </HBox>

        </content>

    </Panel>

</mvc:View>