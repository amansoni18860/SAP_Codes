<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Panel
        width="400px"
        headerText="Machine Dashboard">

        <content>

            <VBox class="sapUiSmallMargin">

                <HBox alignItems="Center">

                    <core:Icon
                        src="sap-icon://factory"
                        size="2rem"
                        color="#0a6ed1"/>

                    <Title
                        text="{$this>title}"
                        class="sapUiTinyMarginBegin"/>

                </HBox>

                <ObjectNumber
                    number="{$this>temperature}"
                    unit="°C"/>

                <ObjectStatus
                    text="{$this>status}"
                    state="Warning"/>

            </VBox>

        </content>

    </Panel>

</core:FragmentDefinition>