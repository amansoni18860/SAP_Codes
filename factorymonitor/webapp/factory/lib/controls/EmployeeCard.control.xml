<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Panel
        width="350px"
        headerText="Bonus Details">

        <content>

            <VBox class="sapUiSmallMargin">

                <Title
                    text="{$this>employeeName}" />

                <ObjectNumber
                    number="{$this>salary}"
                    unit="₹" />

                <ObjectStatus
                    text="Bonus: {$this>bonus}" />

            </VBox>

        </content>

    </Panel>

</core:FragmentDefinition>