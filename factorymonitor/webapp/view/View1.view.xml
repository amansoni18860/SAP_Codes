<mvc:View
    controllerName="com.training.factory.factorymonitor.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:lib="factory.lib.controls">

    <Page title="Machine Monitor">

        <content>

            <VBox class="sapUiMediumMargin">

                <Input
                    id="tempInput"
                    placeholder="Temperature" />

                <Button
                    text="Check Machine"
                    press=".onCheckMachine" />

                <lib:MachineCard
                    id="machineCard"
                    title="Boiler Unit"/>

            </VBox>

        </content>

    </Page>

</mvc:View>