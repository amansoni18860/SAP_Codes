<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Panel
        class="sapUiResponsiveMargin">

        <VBox
            class="sapUiMediumMargin">

            <Title
                text="{$this>customerName}" />

            <ObjectIdentifier
                title="{$this>customerId}" />

            <ObjectStatus
                text="{$this>city}"
                state="Information" />

            <ObjectNumber
                number="{$this>creditLimit}"
                unit="INR" />

            <ObjectStatus
                text="{$this>status}"
                state="Success" />

            <HBox class="sapUiSmallMarginTop">

                <Button
                    text="Approve"
                    type="Accept"
                    press=".onApprove" />

                <Button
                    text="Reject"
                    type="Reject"
                    press=".onReject"
                    class="sapUiTinyMarginBegin" />

            </HBox>

        </VBox>

    </Panel>

</core:FragmentDefinition>