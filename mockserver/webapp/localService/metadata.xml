<?xml version="1.0" encoding="utf-8"?>

<edmx:Edmx
    Version="1.0"
    xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">

    <edmx:DataServices
        m:DataServiceVersion="2.0"
        xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata">

        <Schema
            Namespace="Namespace"
            xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

            <!-- ===================================== -->
            <!-- Employee Entity                       -->
            <!-- ===================================== -->

            <EntityType Name="Employee">

                <Key>
                    <PropertyRef Name="EmployeeID"/>
                </Key>

                <Property
                    Name="EmployeeID"
                    Type="Edm.Int32"
                    Nullable="false" />

                <Property
                    Name="FirstName"
                    Type="Edm.String"
                    Nullable="false"
                    MaxLength="50" />

                <Property
                    Name="LastName"
                    Type="Edm.String"
                    Nullable="false"
                    MaxLength="50" />

                <Property
                    Name="Email"
                    Type="Edm.String"
                    Nullable="false"
                    MaxLength="100" />

                <Property
                    Name="HireDate"
                    Type="Edm.DateTime"
                    Nullable="false" />

                <Property
                    Name="Salary"
                    Type="Edm.Decimal"
                    Nullable="false"
                    Precision="18"
                    Scale="2" />

                <Property
                    Name="DepartmentID"
                    Type="Edm.Int32"
                    Nullable="false" />

                <!-- Employee -> Department -->
                <NavigationProperty
                    Name="Department"
                    Relationship="Namespace.EmployeeDepartment"
                    FromRole="Employee"
                    ToRole="Department" />

            </EntityType>


            <!-- ===================================== -->
            <!-- Department Entity                     -->
            <!-- ===================================== -->

            <EntityType Name="Department">

                <Key>
                    <PropertyRef Name="DepartmentID"/>
                </Key>

                <Property
                    Name="DepartmentID"
                    Type="Edm.Int32"
                    Nullable="false" />

                <Property
                    Name="DepartmentName"
                    Type="Edm.String"
                    Nullable="false"
                    MaxLength="100" />

                <!-- Department -> Employees -->
                <NavigationProperty
                    Name="Employees"
                    Relationship="Namespace.EmployeeDepartment"
                    FromRole="Department"
                    ToRole="Employee" />

            </EntityType>


            <!-- ===================================== -->
            <!-- Association                           -->
            <!-- ===================================== -->

            <Association Name="EmployeeDepartment">

                <!-- Many Employees -->
                <End
                    Type="Namespace.Employee"
                    Role="Employee"
                    Multiplicity="*" />

                <!-- One Department -->
                <End
                    Type="Namespace.Department"
                    Role="Department"
                    Multiplicity="1" />

                <ReferentialConstraint>

                    <Principal Role="Department">
                        <PropertyRef Name="DepartmentID"/>
                    </Principal>

                    <Dependent Role="Employee">
                        <PropertyRef Name="DepartmentID"/>
                    </Dependent>

                </ReferentialConstraint>

            </Association>


            <!-- ===================================== -->
            <!-- Entity Container                      -->
            <!-- ===================================== -->

            <EntityContainer
                Name="Container"
                m:IsDefaultEntityContainer="true">

                <EntitySet
                    Name="Employees"
                    EntityType="Namespace.Employee" />

                <EntitySet
                    Name="Departments"
                    EntityType="Namespace.Department" />

                <AssociationSet
                    Name="EmployeeDepartmentSet"
                    Association="Namespace.EmployeeDepartment">

                    <End
                        Role="Employee"
                        EntitySet="Employees" />

                    <End
                        Role="Department"
                        EntitySet="Departments" />

                </AssociationSet>

            </EntityContainer>

        </Schema>

    </edmx:DataServices>

</edmx:Edmx>