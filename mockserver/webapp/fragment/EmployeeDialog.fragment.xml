<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="Employee">

        <VBox class="sapUiSmallMargin">

            <Input
                placeholder="First Name"
                value="{dialog>/FirstName}" />

            <Input
                placeholder="Last Name"
                value="{dialog>/LastName}" />

            <Input
                placeholder="Email"
                value="{dialog>/Email}" />

            <Input
                placeholder="Salary"
                type="Number"
                value="{dialog>/Salary}" />

            <Select
                selectedKey="{dialog>/DepartmentID}"
                items="{/Departments}">

                <core:Item
                    key="{DepartmentID}"
                    text="{DepartmentName}" />

            </Select>

        </VBox>

        <beginButton>
            <Button
                text="Save"
                press=".onSave" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCancel" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>
