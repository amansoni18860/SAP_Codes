<?xml version="1.0" encoding="utf-8"?>

<edmx:Edmx
    Version="1.0"
    xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">

    <edmx:DataServices
        m:DataServiceVersion="2.0"
        xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata">

        <Schema
            Namespace="ProductService"
            xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

            <!-- ================================================= -->
            <!-- Product Entity                                     -->
            <!-- Represents products in the catalog                 -->
            <!-- ================================================= -->

            <EntityType Name="Product">

                <!-- Primary Key -->
                <Key>
                    <PropertyRef Name="ProductID"/>
                </Key>

                <!-- Unique Product ID -->
                <Property
                    Name="ProductID"
                    Type="Edm.Int32"
                    Nullable="false" />

                <!-- Product Name -->
                <Property
                    Name="Name"
                    Type="Edm.String"
                    Nullable="false"
                    MaxLength="100" />

                <!-- Product Category -->
                <Property
                    Name="Category"
                    Type="Edm.String"
                    Nullable="false"
                    MaxLength="50" />

                <!-- Product Price -->
                <Property
                    Name="Price"
                    Type="Edm.Decimal"
                    Nullable="false"
                    Precision="18"
                    Scale="2" />

                <!-- Available Stock -->
                <Property
                    Name="Stock"
                    Type="Edm.Int32"
                    Nullable="false" />

                <!-- Product Creation Date -->
                <Property
                    Name="CreatedOn"
                    Type="Edm.DateTime"
                    Nullable="false" />

            </EntityType>

            <!-- ================================================= -->
            <!-- Entity Container                                  -->
            <!-- Exposes Product entity as Products entity set      -->
            <!-- ================================================= -->

            <EntityContainer
                Name="Container"
                m:IsDefaultEntityContainer="true">

                <!-- Products Endpoint -->
                <EntitySet
                    Name="Products"
                    EntityType="ProductService.Product" />

            </EntityContainer>

        </Schema>

    </edmx:DataServices>

</edmx:Edmx>
