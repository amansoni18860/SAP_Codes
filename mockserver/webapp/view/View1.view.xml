<mvc:View
    controllerName="demo.mock.mockserver.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <content>
            <Table
                id="employeeTable"
                items="{
        path: '/Employees',
        parameters: {
            expand: 'Department'
        }
    }"
                mode="SingleSelectLeft"
            >
                <headerToolbar>
                    <Toolbar>
                        <Title text="{i18n>employeeList}" />

                        <SearchField
                            liveChange=".onSearch"
                            width="200px"
                            placeholder="Search by first name"
                        />

                        <SearchField
                            liveChange=".onMultiSearch"
                            width="200px"
                            placeholder="Search by any field"
                        
                        />

                        <ToolbarSpacer />

                        <Button
                            text="Create"
                            press=".onCreate"
                        />

                        <Button
                            text="Edit"
                            press=".onEdit"
                        />

                        <Button
                            text="Delete"
                            press=".onDelete"
                        />

                        <Button
                            text="Refresh"
                            press=".onRefresh"
                        />
                        
<Button
    text="Export"
    icon="sap-icon://excel-attachment"
    press=".onExport" />

                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="{i18n>firstName}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>lastName}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>email}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>department}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>hireDate}" />
                    </Column>
                    <Column>

    <HBox alignItems="Center">

        <Text text="{i18n>salary}" />

        <Button
            id="salarySortBtn"
            icon="sap-icon://sort-ascending"
            press=".onSortBySalary"
            type="Transparent" />

    </HBox>

</Column>
                </columns>
                <items>
                    <ColumnListItem type="Active">
                        <cells>
                            <Text text="{FirstName}" />
                            <Text text="{LastName}" />
                            <Text text="{Email}" />
                            <Text text="{Department/DepartmentName}" />
                            <Text
                                text="{path: 'HireDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"
                            />
                            <Text text="{Salary}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
