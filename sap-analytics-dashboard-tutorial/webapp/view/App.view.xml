<!--
  App.view.xml is the main SAPUI5 XML view for this dashboard.
  XML views describe the UI with tags. JavaScript logic stays in App.controller.js.
-->
<mvc:View
  controllerName="sap.analytics.dashboard.tutorial.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:layout="sap.ui.layout"
  xmlns:viz="sap.viz.ui5.controls"
  xmlns:viz.data="sap.viz.ui5.data"
  xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
  displayBlock="true">
  <!--
    mvc:View
    - controllerName connects this XML file to App.controller.js.
    - xmlns="sap.m" makes sap.m controls available without a prefix.
    - Other xmlns entries add prefixed controls such as f:DynamicPage and viz:VizFrame.
  -->

  <!-- f:DynamicPage is a Fiori page layout with title, optional header, and content. -->
  <f:DynamicPage id="page" fitContent="true" class="dashboardPage">
    <!-- Page title area. It stays at the top and can contain actions. -->
    <f:title>
      <f:DynamicPageTitle>
        <!-- Main heading shown in the shell title area. -->
        <f:heading>
          <Title text="Analytics Workspace" level="H1" />
        </f:heading>

        <!-- Additional title text shown when the header is expanded. -->
        <f:expandedContent>
          <Text text="Sales performance, pipeline health, and regional trends" />
        </f:expandedContent>

        <!-- Actions placed on the right side of the title bar. -->
        <f:actions>
          <!-- press=".onResetFilters" calls onResetFilters in App.controller.js. -->
          <Button text="Reset" icon="sap-icon://reset" press=".onResetFilters" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <!-- Header area used for dashboard filters. -->
    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <!-- HBox places children horizontally. wrap="Wrap" lets filters move to new rows. -->
        <HBox wrap="Wrap" class="filterBar">
          <!-- VBox stacks the Label above the Select. -->
          <VBox class="filterItem">
            <Label text="Year" labelFor="yearFilter" />
            <!--
              Select is a dropdown.
              selectedKey="{view>/selectedYear}" binds to the named "view" model.
              items="{/years}" repeats core:Item for each year in mockData.json.
            -->
            <Select id="yearFilter" selectedKey="{view>/selectedYear}" change=".onFilterChange" items="{/years}">
              <core:Item key="{key}" text="{text}" />
            </Select>
          </VBox>

          <VBox class="filterItem">
            <Label text="Region" labelFor="regionFilter" />
            <!-- The selected region is stored in the "view" model and used by the controller. -->
            <Select id="regionFilter" selectedKey="{view>/selectedRegion}" change=".onFilterChange" items="{/regions}">
              <core:Item key="{key}" text="{text}" />
            </Select>
          </VBox>

          <VBox class="filterItem">
            <Label text="Category" labelFor="categoryFilter" />
            <!-- The category dropdown uses /categories from the default JSON model. -->
            <Select id="categoryFilter" selectedKey="{view>/selectedCategory}" change=".onFilterChange" items="{/categories}">
              <core:Item key="{key}" text="{text}" />
            </Select>
          </VBox>
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <!-- Main page content starts here. -->
    <f:content>
      <!-- VBox stacks dashboard sections vertically. -->
      <VBox class="contentShell">
        <!--
          layout:Grid creates a responsive grid.
          defaultSpan="XL2 L2 M4 S12" means:
          - extra large: each item uses 2 of 12 columns
          - large: 2 of 12
          - medium: 4 of 12
          - small: 12 of 12, full width on phone
          content="{/dashboard/kpis}" repeats the GenericTile for every KPI object.
        -->
        <layout:Grid defaultSpan="XL2 L2 M4 S12" hSpacing="1" vSpacing="1" containerQuery="true" content="{/dashboard/kpis}">
          <!-- GenericTile is the standard Fiori tile control for summary KPIs. -->
          <GenericTile header="{title}" frameType="OneByOne" class="kpiTile">
            <TileContent unit="">
              <!-- NumericContent shows one KPI value, icon, and semantic color. -->
              <NumericContent value="{value}" icon="{icon}" valueColor="{state}" />
            </TileContent>
          </GenericTile>
        </layout:Grid>

        <!-- Two-column chart area on desktop, single column on smaller screens. -->
        <layout:Grid defaultSpan="XL8 L8 M12 S12" hSpacing="1" vSpacing="1" containerQuery="true">
          <!-- Panel groups one chart with a visible header. -->
          <Panel headerText="Monthly Revenue and Orders" class="dashboardPanel">
            <!--
              VizFrame is SAPUI5's chart control.
              vizType="dual_combination" creates bars/lines with two value axes.
            -->
            <viz:VizFrame
              id="monthlyRevenueChart"
              height="22rem"
              width="100%"
              vizType="dual_combination"
              uiConfig="{applicationSet:'fiori'}">
              <!-- Dataset tells the chart which model array to read. -->
              <viz:dataset>
                <viz.data:FlattenedDataset data="{/dashboard/monthlyRevenue}">
                  <!-- Dimension means category/group field on a chart. -->
                  <viz.data:dimensions>
                    <viz.data:DimensionDefinition name="Month" value="{month}" />
                  </viz.data:dimensions>
                  <!-- Measure means numeric value fields on a chart. -->
                  <viz.data:measures>
                    <viz.data:MeasureDefinition name="Revenue" value="{revenue}" />
                    <viz.data:MeasureDefinition name="Orders" value="{orders}" />
                  </viz.data:measures>
                </viz.data:FlattenedDataset>
              </viz:dataset>
              <!-- Feeds map measures/dimensions to chart roles like axes. -->
              <viz:feeds>
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Revenue" />
                <viz.feeds:FeedItem uid="valueAxis2" type="Measure" values="Orders" />
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month" />
              </viz:feeds>
            </viz:VizFrame>
          </Panel>

          <Panel headerText="Pipeline by Stage" class="dashboardPanel">
            <!-- Bar chart showing opportunity pipeline value for each sales stage. -->
            <viz:VizFrame
              id="pipelineChart"
              height="22rem"
              width="100%"
              vizType="bar"
              uiConfig="{applicationSet:'fiori'}">
              <viz:dataset>
                <viz.data:FlattenedDataset data="{/dashboard/pipelineByStage}">
                  <viz.data:dimensions>
                    <!-- Stage becomes the category label on the chart. -->
                    <viz.data:DimensionDefinition name="Stage" value="{stage}" />
                  </viz.data:dimensions>
                  <viz.data:measures>
                    <!-- Value and Deals come from mockData.json pipeline entries. -->
                    <viz.data:MeasureDefinition name="Value" value="{value}" />
                    <viz.data:MeasureDefinition name="Deals" value="{count}" />
                  </viz.data:measures>
                </viz.data:FlattenedDataset>
              </viz:dataset>
              <viz:feeds>
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Value" />
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Stage" />
              </viz:feeds>
            </viz:VizFrame>
          </Panel>
        </layout:Grid>

        <!-- Second chart row. -->
        <layout:Grid defaultSpan="XL6 L6 M12 S12" hSpacing="1" vSpacing="1" containerQuery="true">
          <Panel headerText="Revenue by Region" class="dashboardPanel">
            <!-- Donut chart. It uses color segments for regions and size for revenue. -->
            <viz:VizFrame
              id="regionRevenueChart"
              height="20rem"
              width="100%"
              vizType="donut"
              uiConfig="{applicationSet:'fiori'}">
              <viz:dataset>
                <viz.data:FlattenedDataset data="{/dashboard/revenueByRegion}">
                  <viz.data:dimensions>
                    <!-- Region is the segment name. -->
                    <viz.data:DimensionDefinition name="Region" value="{region}" />
                  </viz.data:dimensions>
                  <viz.data:measures>
                    <!-- Revenue decides the segment size. -->
                    <viz.data:MeasureDefinition name="Revenue" value="{revenue}" />
                  </viz.data:measures>
                </viz.data:FlattenedDataset>
              </viz:dataset>
              <viz:feeds>
                <!-- Donut charts use "size" for the measure and "color" for categories. -->
                <viz.feeds:FeedItem uid="size" type="Measure" values="Revenue" />
                <viz.feeds:FeedItem uid="color" type="Dimension" values="Region" />
              </viz:feeds>
            </viz:VizFrame>
          </Panel>

          <Panel headerText="Revenue by Category" class="dashboardPanel">
            <!-- Column chart comparing categories such as Cloud ERP and Analytics. -->
            <viz:VizFrame
              id="categoryRevenueChart"
              height="20rem"
              width="100%"
              vizType="column"
              uiConfig="{applicationSet:'fiori'}">
              <viz:dataset>
                <viz.data:FlattenedDataset data="{/dashboard/revenueByCategory}">
                  <viz.data:dimensions>
                    <viz.data:DimensionDefinition name="Category" value="{category}" />
                  </viz.data:dimensions>
                  <viz.data:measures>
                    <viz.data:MeasureDefinition name="Revenue" value="{revenue}" />
                    <viz.data:MeasureDefinition name="Orders" value="{orders}" />
                  </viz.data:measures>
                </viz.data:FlattenedDataset>
              </viz:dataset>
              <viz:feeds>
                <!-- For a column chart, valueAxis is the vertical axis and categoryAxis is horizontal. -->
                <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Revenue" />
                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Category" />
              </viz:feeds>
            </viz:VizFrame>
          </Panel>
        </layout:Grid>

        <!-- Table section for detailed records after the summary charts. -->
        <Panel headerText="Top Opportunities" class="dashboardPanel">
          <!--
            Table items="{/dashboard/topOpportunities}" repeats one ColumnListItem per row.
            growing="true" enables loading more rows as the table grows.
            sticky="ColumnHeaders" keeps headers visible while scrolling.
          -->
          <Table items="{/dashboard/topOpportunities}" growing="true" sticky="ColumnHeaders">
            <!-- Column definitions control headers, alignment, and phone/tablet behavior. -->
            <columns>
              <Column><Text text="Account" /></Column>
              <Column minScreenWidth="Tablet" demandPopin="true"><Text text="Region" /></Column>
              <Column minScreenWidth="Tablet" demandPopin="true"><Text text="Category" /></Column>
              <Column minScreenWidth="Desktop" demandPopin="true"><Text text="Stage" /></Column>
              <Column hAlign="End"><Text text="Value" /></Column>
              <Column hAlign="End"><Text text="Probability" /></Column>
              <Column minScreenWidth="Desktop" demandPopin="true"><Text text="Owner" /></Column>
            </columns>
            <items>
              <!-- ColumnListItem is the row template. Each cell maps to one column above. -->
              <ColumnListItem>
                <cells>
                  <!-- ObjectIdentifier is useful for business objects such as accounts. -->
                  <ObjectIdentifier title="{account}" />
                  <Text text="{region}" />
                  <Text text="{category}" />
                  <!-- Expression binding calculates semantic status color from probability. -->
                  <ObjectStatus text="{stage}" state="{= ${probability} >= 0.7 ? 'Success' : ${probability} >= 0.55 ? 'Warning' : 'Error' }" />
                  <!-- ObjectNumber formats a number with a unit. -->
                  <ObjectNumber number="{value}" unit="USD" />
                  <ObjectNumber number="{= Math.round(${probability} * 100) }" unit="%" />
                  <Text text="{owner}" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </Panel>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
