{
  "_version": "1.58.0",
  "sap.app": {
    "id": "sap.analytics.dashboard.tutorial",
    "type": "application",
    "title": "SAP Analytics Dashboard Tutorial",
    "description": "A learning SAPUI5 analytics dashboard with mock data, KPI tiles, filters, charts, and tables.",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.f": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.viz": {},
        "sap.suite.ui.commons": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "rootView": {
      "viewName": "sap.analytics.dashboard.tutorial.view.App",
      "type": "XML",
      "id": "app"
    }
  }
}
